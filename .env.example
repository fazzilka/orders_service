# App
LOG_LEVEL=INFO
API_PORT=18000
RABBITMQ_MANAGEMENT_PORT=18001

# Postgres (docker-compose uses these variables)
POSTGRES_USER=orders
POSTGRES_PASSWORD=orders
POSTGRES_DB=orders
DATABASE_URL=postgresql+asyncpg://orders:orders@postgres:5432/orders
POSTGRES_WAIT_TIMEOUT=60

# Redis
REDIS_URL=redis://redis:6379/0

# RabbitMQ
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBIT_EXCHANGE=orders.events
RABBIT_QUEUE=orders.new_order
RABBIT_ROUTING_KEY=new_order

# Cache
CACHE_TTL_SECONDS=300

# JWT
JWT_SECRET_KEY=change_in_.env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated)
CORS_ORIGINS=http://localhost,http://127.0.0.1:3000

# Rate limiting (slowapi/limits; use separate Redis DB to avoid mixing with cache/tasks)
RATE_LIMIT_STORAGE_URI=redis://redis:6379/1
RATE_LIMIT_TOKEN=5/minute
RATE_LIMIT_ORDERS=20/minute

# Celery (Redis broker/backend; NOT RabbitMQ event-bus)
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/2
